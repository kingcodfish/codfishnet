# Copy this file to .env and fill in your values before running the server.
# .env is gitignored and will never be committed.

# Required — set a long random string, e.g. run: python -c "import secrets; print(secrets.token_hex(32))"
CODFISHNET_ADMIN=change_me_to_a_strong_secret

# Server bind address and port (default: all interfaces, port 817)
HOST=0.0.0.0
PORT=817

# How often chat history auto-clears (daily | weekly)
CLEAR_INTERVAL=daily
